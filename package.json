{
  "name": "videojs-frames",
  "version": "0.1.0",
  "description": "Framerate plugin with bif fast scroll support",
  "main": "dist/videojs-frames.cjs.js",
  "module": "dist/videojs-frames.es.js",
  "generator-videojs-plugin": {
    "version": "7.6.3"
  },
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "prebuild": "npm run clean",
    "build": "npm run build:css && npm run build:js && npm run build:lang",
    "build:css": "postcss -o dist/videojs-frames.css --config scripts/postcss.config.js src/plugin.css",
    "build:js": "rollup -c scripts/rollup.config.js",
    "build:lang": "vjslang --dir dist/lang",
    "clean": "shx rm -rf ./dist ./test/dist",
    "postclean": "shx mkdir -p ./dist ./test/dist",
    "docs": "npm-run-all docs:*",
    "docs:api": "jsdoc src -c scripts/jsdoc.conf.json -r -d docs/api",
    "docs:toc": "doctoc --notitle README.md",
    "lint": "vjsstandard",
    "server": "karma start scripts/karma.conf.js --singleRun=false --auto-watch",
    "start": "npm-run-all -p server watch",
    "pretest": "npm run lint && npm run build",
    "test": "npm run test:unit && npm run test:verify",
    "posttest": "shx cat test/dist/coverage/text.txt",
    "test:unit": "karma start scripts/karma.conf.js",
    "test:verify": "node scripts/run-vjsverify.js",
    "update-changelog": "conventional-changelog -p videojs -i CHANGELOG.md -s",
    "preversion": "npm test",
    "version": "is-prerelease || npm run update-changelog && git add CHANGELOG.md",
    "watch": "npm-run-all -p watch:*",
    "watch:css": "npm run build:css -- -w",
    "watch:js": "npm run build:js -- -w",
    "prepublishOnly": "npm-run-all build test:verify"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "keywords": [
    "videojs",
    "videojs-plugin"
  ],
  "author": "Samuel East",
  "license": "MIT",
  "vjsstandard": {
    "ignore": [
      "dist",
      "docs",
      "test/dist"
    ]
  },
  "files": [
    "CONTRIBUTING.md",
    "dist/",
    "docs/",
    "index.html",
    "scripts/",
    "src/",
    "test/"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "npx --no-install lint-staged",
      "pre-push": "npm run test"
    }
  },
  "lint-staged": {
    "*.js": [
      "vjsstandard --fix",
      "git add"
    ],
    "README.md": [
      "doctoc --notitle",
      "git add"
    ]
  },
  "dependencies": {
    "global": "^4.4.0",
    "jdataview": "^2.5.0",
    "lodash": "^4.18.1",
    "nouislider": "^14.7.0",
    "video.js": "^8.23.9"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^7.3.0",
    "@videojs/generator-helpers": "^3.2.0",
    "husky": "^4.3.8",
    "jsdoc": "^4.0.5",
    "karma": "^6.4.4",
    "karma-firefox-launcher": "^2.1.3",
    "lint-staged": "^10.5.4",
    "npm-run-all2": "^9.0.2",
    "postcss-cli": "^6.1.3",
    "rollup": "^2.79.2",
    "sinon": "^17.0.2",
    "videojs-generate-karma-config": "^8.1.0",
    "videojs-generate-postcss-config": "^2.1.1",
    "videojs-generate-rollup-config": "^7.0.2",
    "videojs-generator-verify": "^4.1.3",
    "videojs-languages": "^2.0.0",
    "videojs-standard": "^9.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samueleastdev/videojs-timecodes.git"
  }
}
